{
  "extends": "../packages/tsconfig/base.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "target": "ES2022",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": ".",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "noUncheckedIndexedAccess": false,
    "types": ["node", "mocha", "chai"]
  },
  "include": ["./hardhat.config.ts", "./scripts/**/*", "./test/**/*", "./ignition/**/*"]
}
