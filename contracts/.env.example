# Public RPC works for the demo; pin to Alchemy/Infura for stability.
BASE_SEPOLIA_RPC=https://sepolia.base.org

# Ethereum Sepolia (L1) — only needed for deploying the ENS resolver.
ETH_SEPOLIA_RPC=https://ethereum-sepolia-rpc.publicnode.com

# Funded deployer wallet (Base Sepolia faucet ETH for the main contracts;
# Eth Sepolia faucet ETH if you also deploy the ENS resolver to mainnet).
DEPLOYER_PK=

# Backend's hot wallet — granted MINTER_ROLE on Base Sepolia + becomes the
# admin of the ENS resolver on Eth Sepolia. Address only, not the PK.
BACKEND_MINTER_ADDR=

# Basescan API key (free signup) — for `verify` on Base Sepolia.
BASESCAN_API_KEY=

# Etherscan API key (free signup) — for `verify` on Eth Sepolia.
ETHERSCAN_API_KEY=
