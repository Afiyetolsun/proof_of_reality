{
  "name": "@proof-of-reality/proof-bundle",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schema": {
      "types": "./dist/schema.d.ts",
      "import": "./dist/schema.js"
    },
    "./canonical": {
      "types": "./dist/canonical.d.ts",
      "import": "./dist/canonical.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "node --test --experimental-strip-types src/canonical.test.ts"
  },
  "dependencies": {
    "@noble/hashes": "^1.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@proof-of-reality/tsconfig": "workspace:*",
    "typescript": "^5.6.3"
  }
}
