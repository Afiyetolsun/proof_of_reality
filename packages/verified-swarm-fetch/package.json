{
  "name": "@proof-of-reality/verified-swarm-fetch",
  "version": "0.1.0",
  "description": "Trustless Swarm fetch — verifies content addressing client-side. Like helia-verified-fetch, for Swarm.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
