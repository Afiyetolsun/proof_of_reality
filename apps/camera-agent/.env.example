PROOF_API_URL=https://proof-of-reality.vercel.app
PROOF_API_TOKEN=

# Where the USB Armory's signer firmware exposes its HTTP server (over USB CDC Ethernet)
ARMORY_SIGNER_URL=http://10.0.0.1

# "armory" (default), "atecc608", or "mock" for dev without HW
ATTEST_BACKEND=armory

# Org wallet that registered THIS camera. Used as the `attestor` field on every mint.
ORG_ATTESTOR_ADDR=

# How long a capture runs (seconds)
CAPTURE_DURATION_SEC=8

# Display device for the kiosk QR code (or "none" for headless)
KIOSK_DISPLAY=none
