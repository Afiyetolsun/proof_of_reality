# Origin of the @proof-of-reality/api deployment. Used server-side by the
# /api/nonce proxy route. NOT exposed to the client.
PROOF_API_URL=http://localhost:3000

# Public origin of the verifier (apps/viewer). Used to build deep-links from
# CTAs into /token/[id].
NEXT_PUBLIC_VIEWER_BASE_URL=http://localhost:3000

# Token id of a real, minted ProofBundle on Base Sepolia. Drives the primary
# CTA destination. If unset, CTAs fall back to the viewer root.
NEXT_PUBLIC_SAMPLE_TOKEN_ID=

# Public GitHub repo URL for the "Architecture" link.
NEXT_PUBLIC_GITHUB_URL=https://github.com/your-org/proof-of-reality
