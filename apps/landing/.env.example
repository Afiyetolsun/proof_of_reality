# Origin of the @proof-of-reality/api deployment. Used server-side by the
# /api/nonce proxy route. NOT exposed to the client.
PROOF_API_URL=https://api.realityproof.app

# Public origin of the verifier (apps/gallery). Used to build deep-links from
# the landing CTAs into the gallery wall.
NEXT_PUBLIC_VIEWER_BASE_URL=https://app.realityproof.app

# Public GitHub repo URL for the "Architecture" and "GitHub" links.
NEXT_PUBLIC_GITHUB_URL=https://github.com/Afiyetolsun/proof_of_reality

# ENS parent name. Each Reality NFT mint publishes a subname under this
# parent on Eth Sepolia. Used for the "View on ENS" deep-links.
NEXT_PUBLIC_ENS_PARENT_NAME=realityproof.eth
NEXT_PUBLIC_ENS_APP_BASE_URL=https://sepolia.app.ens.domains

# ENS subname rendered in the hero <ProofHero>. Resolves via the gallery's
# /api/resolve endpoint at NEXT_PUBLIC_VIEWER_BASE_URL.
NEXT_PUBLIC_HERO_ENS_NAME=pizza.realityproof.eth

# Contact form — Telegram bot notifications.
# Create a bot via @BotFather, then get the chat ID by messaging the bot and
# calling https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX).
# Only loaded after the user accepts the cookie banner.
NEXT_PUBLIC_GA_MEASUREMENT_ID=
