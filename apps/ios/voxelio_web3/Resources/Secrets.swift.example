// Copy this file to Secrets.swift and fill in real values.
// Secrets.swift is gitignored — never commit it.

import Foundation

nonisolated enum Secrets {
    /// Vercel relay base URL — see voxelio_web3_api repo.
    static let baseURL = URL(string: "http://localhost:3000")!

    /// Shared secret matching IOS_SHARED_SECRET on the relay.
    /// Sent in X-Voxelio-Key on every request.
    static let sharedKey = "changeme"
}
