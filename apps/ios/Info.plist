<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- ===== Standard bundle keys =====
	     Auto-injected when GENERATE_INFOPLIST_FILE = YES, must be declared
	     explicitly with $(VAR) substitutions when using a manual Info.plist. -->
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundleDisplayName</key>
	<string>Proof of Reality</string>
	<key>CFBundlePackageType</key>
	<string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>

	<!-- ===== Permission strings ===== -->
	<key>NSCameraUsageDescription</key>
	<string>Proof of Reality uses the camera to scan the physical object you are proving exists.</string>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>Location is recorded so the proof can attest where the scan happened.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>The microphone records the spoken cosmic nonce that binds this scan to a moment in time.</string>
	<key>NSMotionUsageDescription</key>
	<string>Motion sensor data is part of the proof bundle that shows the scan came from a real device.</string>
	<key>NSLocalNetworkUsageDescription</key>
	<string>Proof of Reality talks to a local relay (your laptop on the same Wi-Fi) during development and demos.</string>

	<!-- ===== App Transport Security =====
	     We talk to:
	       - Vercel relay over HTTPS (no exception needed)
	       - A self-hosted Bee node at http://<vps-ip>:1633 for big-scene
	         direct uploads (Vercel's body cap doesn't fit a 10 MB USDZ).
	     NSAllowsLocalNetworking covers laptop-local relays at 192.168.* / .local;
	     NSAllowsArbitraryLoads is required for the public-IP Bee node since
	     iOS doesn't accept bare IPs in NSExceptionDomains for production builds.
	     If you put Bee behind a TLS-terminating reverse proxy with a domain
	     name later, drop NSAllowsArbitraryLoads and use NSExceptionDomains
	     scoped to that hostname only. -->
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsLocalNetworking</key>
		<true/>
		<key>NSAllowsArbitraryLoads</key>
		<true/>
		<key>NSAllowsArbitraryLoadsInWebContent</key>
		<true/>
		<!-- Explicit per-host exception. iOS 26 increasingly ignores
		     NSAllowsArbitraryLoads for direct IP-literal URLs unless
		     paired with an exception entry. Update this IP whenever
		     swarmBeeURL in Secrets.swift changes. -->
		<key>NSExceptionDomains</key>
		<dict>
			<key>89.116.31.10</key>
			<dict>
				<key>NSExceptionAllowsInsecureHTTPLoads</key>
				<true/>
				<key>NSIncludesSubdomains</key>
				<false/>
				<key>NSExceptionMinimumTLSVersion</key>
				<string>TLSv1.0</string>
				<key>NSExceptionRequiresForwardSecrecy</key>
				<false/>
			</dict>
		</dict>
	</dict>

	<!-- ===== Scene + launch ===== -->
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>
	<key>UIApplicationSceneManifest</key>
	<dict>
		<key>UIApplicationSupportsMultipleScenes</key>
		<false/>
	</dict>
	<key>UILaunchScreen</key>
	<dict/>

	<!-- ===== Orientations ===== -->
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
</dict>
</plist>
