# --- iOS ↔ backend shared secret (used as Bearer token by both clients) ---
IOS_SHARED_SECRET=
# --- 3rd-party camera shared secret (OAK + USB Armory, etc.) ---
# Optional. When unset only IOS_SHARED_SECRET is accepted. Setting this lets
# you issue + rotate camera credentials independently of iOS.
CAMERA_SHARED_SECRET=

# --- SpaceComputer Orbitport (cTRNG + KMS) ---
ORBITPORT_CLIENT_ID=
ORBITPORT_CLIENT_SECRET=
# Pre-create the cosigner key once via a CLI script and pin its KeyId here.
KMS_COSIGNER_KEY_ID=
# Pinned KMS pubkey, copied into the viewer for verification independence.
KMS_COSIGNER_PUBKEY=

# --- Swarm ---
SWARM_BEE_URL=https://api.gateway.ethswarm.org
SWARM_POSTAGE_BATCH_ID=
# Fallback: STORAGE_BACKEND=ipfs uses Pinata if Swarm flakes
STORAGE_BACKEND=swarm
PINATA_JWT=

# --- Base Sepolia ---
BASE_SEPOLIA_RPC=https://sepolia.base.org
MINTER_PRIVATE_KEY=
REALITY_PROOF_ADDRESS=
DEVICE_REGISTRY_ADDRESS=

# --- ENS (Ethereum Sepolia, separate chain from Base Sepolia) ---
# Backend publishes a per-mint subname under ENS_PARENT_NAME pointing at
# ENS_RESOLVER_ADDRESS. All three must be set together; if any is missing,
# the mint still goes through but the ENS publication is silently skipped.
ETH_SEPOLIA_RPC=https://ethereum-sepolia-rpc.publicnode.com
ENS_PARENT_NAME=realityproof.eth
ENS_RESOLVER_ADDRESS=
ENS_PARENT_DOMAIN=realityproof.eth

# --- Misc ---
LOG_LEVEL=info
