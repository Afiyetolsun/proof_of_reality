# --- iOS ↔ backend shared secret (used as Bearer token by both clients) ---
IOS_SHARED_SECRET=

# --- SpaceComputer Orbitport (cTRNG + KMS) ---
ORBITPORT_CLIENT_ID=
ORBITPORT_CLIENT_SECRET=
# Pre-create the cosigner key once via a CLI script and pin its KeyId here.
KMS_COSIGNER_KEY_ID=
# Pinned KMS pubkey, copied into the viewer for verification independence.
KMS_COSIGNER_PUBKEY=

# --- Swarm ---
SWARM_BEE_URL=https://api.gateway.ethswarm.org
SWARM_POSTAGE_BATCH_ID=
# Fallback: STORAGE_BACKEND=ipfs uses Pinata if Swarm flakes
STORAGE_BACKEND=swarm
PINATA_JWT=

# --- Base Sepolia ---
BASE_SEPOLIA_RPC=https://sepolia.base.org
MINTER_PRIVATE_KEY=
REALITY_PROOF_ADDRESS=
DEVICE_REGISTRY_ADDRESS=

# --- ENS (optional bounty path) ---
ENS_PARENT_DOMAIN=realityproof.eth

# --- Misc ---
LOG_LEVEL=info
