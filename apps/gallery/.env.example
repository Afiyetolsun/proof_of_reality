# Parent ENS name to enumerate. Every Reality NFT mint creates a subname
# under this parent on Eth Sepolia.
NEXT_PUBLIC_ENS_PARENT_NAME=realityproof.eth

# ENS Sepolia subgraph endpoint. Used to enumerate subnames of the parent
# for the gallery grid.
NEXT_PUBLIC_ENS_SUBGRAPH_URL=https://api.studio.thegraph.com/query/49574/enssepolia/version/latest

# Eth Sepolia RPC. Used for both the multicall on the gallery grid AND
# the per-name detail page's full record resolve.
NEXT_PUBLIC_ETH_SEPOLIA_RPC=https://ethereum-sepolia-rpc.publicnode.com

# Base Sepolia RPC. Used by the per-name page to read the on-chain proof
# struct + DeviceRegistry status.
NEXT_PUBLIC_BASE_SEPOLIA_RPC=https://sepolia.base.org

# Optional: pin the expected resolver address. If unset, we accept any
# resolver registered for the subname (the subgraph already filters to
# realityproof.eth subnames).
NEXT_PUBLIC_ENS_RESOLVER_ADDRESS=

# Contracts on Base Sepolia (from docs/private/deployments.md).
NEXT_PUBLIC_REALITY_PROOF_ADDRESS=
NEXT_PUBLIC_DEVICE_REGISTRY_ADDRESS=

# Pinned witness pubkeys (from docs/private/deployments.md).
NEXT_PUBLIC_KMS_COSIGNER_PUBKEY=
NEXT_PUBLIC_SAT_PUBKEY=

# Public Swarm gateway. Used both as a fallback for the /api/scene
# proxy and for "open in gateway" links from cards.
NEXT_PUBLIC_SWARM_GATEWAY=https://api.gateway.ethswarm.org

# Optional: a Bee node we control, used as a primary fetch source for
# faster + more-reliable retrieval. Falls back to the public gateway.
NEXT_PUBLIC_BEE_LOCAL=

# ENS app deep link (footer "View on ENS").
NEXT_PUBLIC_ENS_APP_BASE_URL=https://sepolia.app.ens.domains
