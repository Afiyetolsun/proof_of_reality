# Bee keystore password (min 8 chars). Persisted in the docker volume.
# CHANGE THIS before first run; you cannot recover funds without it.
BEE_PASSWORD=changeme-please

# Optional: private Gnosis Chain RPC for reliability. The default
# (rpc.gnosis.gateway.fm) is public + free but rate-limited.
# Recommended for prod: Alchemy, dRPC, or your own node.
# BEE_BLOCKCHAIN_RPC_ENDPOINT=https://gnosis-mainnet.g.alchemy.com/v2/<key>

# Optional: when running on a VPS, set this to <public-ip>:1634 so
# other Bee nodes can reach your P2P port.
# BEE_NAT_ADDR=12.34.56.78:1634
