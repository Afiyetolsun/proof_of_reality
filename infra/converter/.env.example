# URL of the Bee node the converter fetches USDZ from + uploads GLB to.
# Default works on Linux (Docker → host bridge → Bee at host:1633).
# On macOS Docker Desktop, host.docker.internal works the same way.
BEE_URL=http://host.docker.internal:1633

# Postage batch ID the converter uses to upload the converted GLB back
# to Bee. Get this from `cd infra/swarm && ./bee-setup.sh status` once
# you've bought a stamp. Example: 810e263a9eba821cfebd943cbf1e4885…
STAMP_ID=
