{
  "name": "proof-of-reality",
  "private": true,
  "version": "0.1.0",
  "description": "Web3 oracle for the physical world. ETHPrague 2026.",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm -r --parallel run build",
    "dev:api": "pnpm --filter @proof-of-reality/api dev",
    "dev:viewer": "pnpm --filter @proof-of-reality/viewer dev",
    "build:contracts": "pnpm --filter @proof-of-reality/contracts compile",
    "test:contracts": "pnpm --filter @proof-of-reality/contracts test",
    "deploy:contracts": "pnpm --filter @proof-of-reality/contracts deploy:sepolia",
    "abi:sync": "pnpm --filter @proof-of-reality/contracts-abi sync",
    "lint": "pnpm -r --parallel run lint",
    "typecheck": "pnpm -r --parallel run typecheck",
    "agent:setup": "cd apps/camera-agent && uv sync",
    "agent:run": "cd apps/camera-agent && uv run proof-agent"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "@types/node": "^22.7.5"
  },
  "pnpm": {
    "overrides": {
      "viem": "2.21.45"
    }
  }
}
